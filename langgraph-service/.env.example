# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres direct connection — used by LangGraph checkpointer
# Find in Supabase: Settings > Database > Connection string > URI (use port 5432, not 6543)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Brave Search
BRAVE_API_KEY=your-brave-key

# CORS — set to your Vercel domain in production
CORS_ORIGIN=https://your-app.vercel.app

# Dev accounts that bypass rate limits (comma-separated)
DEV_BYPASS_EMAILS=app.mentora.ai@gmail.com
